pipeline {
    agent any
    stages {
        stage('build') {
            steps {
                echo "Building"
            }
        }
         stage('Test') {
            steps {
               echo "Testing"
            }
        }
        stage('Deploy') {
            steps {
                echo "Deploying"
            }
        }
    }
    post { 
        always { 
            echo 'I will always say Hello again!'
        }
        success {
            echo "pipeline success"
        }
        failure {
            echo "pipeline failure"
        }
    }
    
}